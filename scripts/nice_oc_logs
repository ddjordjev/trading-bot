#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks so this works when installed to /usr/local/bin.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
FORMATTER="$ROOT/scripts/openclaw_logs_overview.py"
PY="$ROOT/.venv/bin/python"

if [ ! -f "$FORMATTER" ]; then
  echo "Missing formatter: $FORMATTER" >&2
  exit 1
fi

if [ ! -x "$PY" ]; then
  if command -v python3 >/dev/null 2>&1; then
    PY="python3"
  else
    echo "Python not found. Expected $ROOT/.venv/bin/python or python3 on PATH." >&2
    exit 1
  fi
fi

# Usage:
#   nice_oc_logs
#   nice_oc_logs --summary-every 60
#   nice_oc_logs --file /path/to/openclaw.log
if [ "${1:-}" = "--file" ]; then
  if [ -z "${2:-}" ]; then
    echo "Usage: nice_oc_logs --file /path/to/openclaw.log [formatter args...]" >&2
    exit 1
  fi
  FILE_PATH="$2"
  shift 2
  exec "$PY" "$FORMATTER" "$FILE_PATH" "$@"
fi

exec openclaw logs --json --follow | "$PY" "$FORMATTER" "$@"
