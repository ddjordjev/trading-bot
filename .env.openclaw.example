# -----------------------------------------------------------------------------
# OpenClaw integration template (no secrets)
# Copy values into your local .env / deployment env as needed.
# -----------------------------------------------------------------------------

# Hub-side OpenClaw polling (used by bot-hub monitor)
# Local no-auth baseline:
# OPENCLAW_URL=http://localhost:18080/intel
OPENCLAW_ENABLED=true
OPENCLAW_URL=http://host.docker.internal:18080/intel
OPENCLAW_TOKEN=
OPENCLAW_POLL_INTERVAL=120
OPENCLAW_TIMEOUT_SECONDS=8

# Optional: OpenClaw intel bridge runtime
OPENCLAW_BRIDGE_HOST=0.0.0.0
OPENCLAW_BRIDGE_PORT=18080
OPENCLAW_BRIDGE_HUB_URL=http://localhost:9035
OPENCLAW_BRIDGE_HUB_TOKEN=
OPENCLAW_BRIDGE_TIMEOUT_SECONDS=8
OPENCLAW_BRIDGE_MAX_LATENCY_SECONDS=6.5

# Local model lane (zero-cost, first-pass advisory)
OPENCLAW_BRIDGE_LOCAL_ENABLED=false
OPENCLAW_BRIDGE_LOCAL_OLLAMA_URL=http://127.0.0.1:11434
OPENCLAW_BRIDGE_LOCAL_MODEL=qwen2.5:7b-instruct
OPENCLAW_BRIDGE_LOCAL_TIMEOUT_SECONDS=5
OPENCLAW_BRIDGE_LOCAL_RECENT_EXAMPLES=2

# Paid model lane (primary production advisory)
OPENCLAW_BRIDGE_PAID_ENABLED=true
ANTHROPIC_API_KEY=
OPENCLAW_BRIDGE_PAID_MODEL_HAIKU=claude-haiku-4-5
OPENCLAW_BRIDGE_PAID_TIMEOUT_SECONDS=20
OPENCLAW_BRIDGE_PAID_MAX_TOKENS=900
OPENCLAW_BRIDGE_PAID_TEMPERATURE=0.2

# Optional escalation lane (disabled by default)
OPENCLAW_BRIDGE_ENABLE_SONNET_ESCALATION=false
OPENCLAW_BRIDGE_PAID_MODEL_SONNET=claude-sonnet-4-5
OPENCLAW_BRIDGE_ESCALATE_CONFIDENCE_LT=0.60
OPENCLAW_BRIDGE_ESCALATE_ON_HIGH_TRIAGE=true
OPENCLAW_BRIDGE_DAILY_SONNET_CALL_CAP=0

# Budget + distillation capture
OPENCLAW_BRIDGE_DAILY_BUDGET_USD=1.67
OPENCLAW_BRIDGE_BUDGET_STATE_PATH=data/openclaw_budget_state.json
OPENCLAW_BRIDGE_DISTILL_PATH=data/openclaw_distill.jsonl

# Keep provider keys in runtime secrets; do not commit them.
