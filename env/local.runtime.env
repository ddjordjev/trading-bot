# Local runtime overrides (non-secret).
# Keep this file focused on local-only behavior.
TRADING_MODE=paper_live
EXCHANGE=binance_testnet
SEND_DAILY_REPORT=false
SESSION_BUDGET=500
BOT_DEFAULT_ENABLED_IDS=extreme,momentum,indicators,meanrev,swing
MAX_CONCURRENT_LIMIT_ORDERS_ON_CEX=3

# Paper-local risk overrides
PAPER_RISK_RELAXED=true
PAPER_MAX_POSITION_SIZE_PCT=50
PAPER_MAX_DAILY_LOSS_PCT=100
PAPER_MAX_CONCURRENT_POSITIONS=10
PAPER_MIN_SIGNAL_STRENGTH=0.2
PAPER_CONSECUTIVE_LOSS_COOLDOWN=999
