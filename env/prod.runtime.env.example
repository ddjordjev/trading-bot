# Production runtime overrides (non-secret template).
# Copy to env/prod.runtime.env on the target host and fill values there.
TRADING_MODE=live
EXCHANGE=binance
SEND_DAILY_REPORT=true
# Fill unified exchange credentials on the target host.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
SESSION_BUDGET=50
BOT_DEFAULT_ENABLED_IDS=indicators

# Small-account balanced profile (~20% used margin on SESSION_BUDGET=50):
# per-trade margin cap ~= SESSION_BUDGET * MAX_POSITION_SIZE_PCT
# total used margin ~= per-trade margin * MAX_CONCURRENT_POSITIONS
MAX_POSITION_SIZE_PCT=10
MAX_CONCURRENT_POSITIONS=2
INITIAL_RISK_AMOUNT=20
DEFAULT_LEVERAGE=5
MIN_TRADEABLE_EQUITY_USDT=30
