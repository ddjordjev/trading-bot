# Production runtime overrides (non-secret template).
# Copy to env/prod.runtime.env on the target host and fill values there.
TRADING_MODE=live
EXCHANGE=binance
SEND_DAILY_REPORT=true
# Fill unified exchange credentials on the target host.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
SESSION_BUDGET=50
BOT_DEFAULT_ENABLED_IDS=indicators
