# Trading Mode:
#   paper_local — simulated trades locally (PaperExchange), nothing hits the exchange
#   paper_live  — real orders on exchange testnet (e.g. demo.binance.com), fake money
#   live        — real orders on production exchange, real money
TRADING_MODE=paper_local

# Exchange
EXCHANGE=binance

# Binance — production keys (used when TRADING_MODE=live)
BINANCE_PROD_API_KEY=
BINANCE_PROD_API_SECRET=
# Binance — testnet keys (used when TRADING_MODE=paper_local or paper_live)
BINANCE_TEST_API_KEY=
BINANCE_TEST_API_SECRET=

# Bybit — production keys (used when TRADING_MODE=live)
BYBIT_PROD_API_KEY=
BYBIT_PROD_API_SECRET=
# Bybit — testnet keys (used when TRADING_MODE=paper_local or paper_live)
BYBIT_TEST_API_KEY=
BYBIT_TEST_API_SECRET=

# What market types YOU want to use on this exchange.
# The bot auto-restricts to what the exchange actually supports:
#   Binance: spot, futures
#   Bybit:   spot, futures
ALLOWED_MARKET_TYPES=spot,futures

# Session budget — how much capital the bot is allowed to use.
# paper_local: this is the simulated starting balance.
# paper_live:  caps usable balance (testnet may have $5K+, bot only uses this much).
# live:        caps usable balance at this amount (safety net).
# Set to 0 to use the full exchange balance (no cap).
SESSION_BUDGET=100

# Default leverage for futures (ignored if futures not allowed)
DEFAULT_LEVERAGE=10

# Risk Management -- capital preservation first
MAX_POSITION_SIZE_PCT=5
MAX_DAILY_LOSS_PCT=3
STOP_LOSS_PCT=1.5
TAKE_PROFIT_PCT=5
MAX_CONCURRENT_POSITIONS=3
MIN_SIGNAL_STRENGTH=0.4
CONSECUTIVE_LOSS_COOLDOWN=3

# Paper-local risk overrides (only when TRADING_MODE=paper_local)
# Set PAPER_RISK_RELAXED=false to use prod risk params in paper_local.
PAPER_RISK_RELAXED=true
PAPER_MAX_POSITION_SIZE_PCT=50
PAPER_MAX_DAILY_LOSS_PCT=100
PAPER_MAX_CONCURRENT_POSITIONS=10
PAPER_MIN_SIGNAL_STRENGTH=0.2
PAPER_CONSECUTIVE_LOSS_COOLDOWN=999

# Tick intervals (seconds) — adaptive, fastest active tier wins
TICK_INTERVAL_SCALP=1
TICK_INTERVAL_ACTIVE=60
TICK_INTERVAL_SWING=300
TICK_INTERVAL_IDLE=60

# Liquidity-aware scaling
BREAKEVEN_LOCK_PCT=5.0
PULLBACK_TRAIL_BUFFER_PCT=4.0
INITIAL_RISK_AMOUNT=50               # fixed $ for first entry (start small!)
MAX_NOTIONAL_POSITION=100000         # stop adding when leveraged position hits $100K
MIN_PROFIT_TO_ADD_PCT=1.0
GAMBLING_BUDGET_PCT=2.0
MIN_LIQUIDITY_VOLUME=1000000

# Pyramid / DCA mode (start small, DCA down, lever up on recovery)
DCA_INTERVAL_PCT=2.0
DCA_MULTIPLIER=1.5
DCA_PROFIT_TO_LEVER_PCT=1.0
DCA_PARTIAL_TAKE_PCT=30

# Hedging (counter-positions on reversal signals)
HEDGE_ENABLED=true
HEDGE_RATIO=0.20
HEDGE_MIN_PROFIT_PCT=3.0
HEDGE_STOP_PCT=1.0
MAX_HEDGES=2

# Email Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFY_EMAIL=your_email@gmail.com

# Notification toggles (comma-separated)
# Available: liquidation,stop_loss,take_profit,order_filled,daily_summary,spike_detected,news_alert
NOTIFICATIONS_ENABLED=liquidation,daily_summary

# Volatility Detection
SPIKE_THRESHOLD_PCT=3.0
VOLATILITY_LOOKBACK_MINUTES=5

# News Monitoring
NEWS_ENABLED=false
NEWS_SOURCES=coindesk,cointelegraph,cryptopanic

# Market Open Windows (UTC hours)
US_MARKET_OPEN_UTC=14
US_MARKET_CLOSE_UTC=21
ASIA_MARKET_OPEN_UTC=1
ASIA_MARKET_CLOSE_UTC=8

# Market Intelligence (external data feeds)
INTEL_ENABLED=true
COINGLASS_API_KEY=                     # optional -- free tier works, paid unlocks more endpoints
FEAR_GREED_POLL=3600                   # Fear & Greed Index poll interval (seconds)
LIQUIDATION_POLL=300                   # CoinGlass liquidation poll interval
MACRO_CALENDAR_POLL=1800               # ForexFactory calendar poll interval
WHALE_SENTIMENT_POLL=300               # CoinGlass funding/OI/L-S poll interval
INTEL_SYMBOLS=BTC,ETH                  # symbols for whale sentiment tracking
MASS_LIQUIDATION_THRESHOLD=1000000000  # $1B = mass liquidation event

# OpenClaw advisory intelligence (hub polls this read-only endpoint)
# Keep this advisory-only: OpenClaw has no execution authority in this system.
OPENCLAW_ENABLED=true
OPENCLAW_URL=http://host.docker.internal:18080/intel
OPENCLAW_TOKEN=                         # optional bearer token
OPENCLAW_POLL_INTERVAL=120              # seconds (min 15)
OPENCLAW_TIMEOUT_SECONDS=8              # seconds (min 2)

# TradingView (free, no key needed -- uses public scanner API)
TV_EXCHANGE=BINANCE                    # exchange name for chart analysis
TV_INTERVALS=1h,4h,1D                  # timeframes: 1m,5m,15m,1h,4h,1D,1W,1M
TV_POLL_INTERVAL=120                   # seconds between refreshes

# CoinMarketCap (works without key, pro key = higher rate limits)
CMC_API_KEY=                           # optional -- get free key at coinmarketcap.com/api
CMC_POLL_INTERVAL=300                  # seconds between trending/gainers refreshes

# CoinGecko (works without key, pro key = higher rate limits)
COINGECKO_API_KEY=                     # optional -- get free key at coingecko.com/api
COINGECKO_POLL_INTERVAL=300            # seconds between trending/market refreshes

# DeFiLlama (free, no key needed — tracks TVL flows across DeFi)
DEFILLAMA_ENABLED=true
DEFILLAMA_POLL_INTERVAL=600

# Santiment (social sentiment — free tier, optional key for rate limits)
SANTIMENT_API_KEY=                        # optional — get at santiment.net
SANTIMENT_POLL_INTERVAL=600

# Financial Modeling Prep (market holiday data — free tier)
FMP_API_KEY=                              # optional — get free key at financialmodelingprep.com

# Dashboard (hub only)
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=9035
DASHBOARD_TOKEN=                       # set a secret token for remote access; empty = no auth
GRAFANA_PORT=3001                      # Grafana dashboard port (embedded in Grafana tab)

# Hub URL — bots POST status snapshots here (set in docker-compose.yml per bot)
# HUB_URL=http://bot-hub:9035

# Exchange platform URL (leave empty for auto-detection)
EXCHANGE_PLATFORM_URL=

# Logging
LOG_LEVEL=INFO
