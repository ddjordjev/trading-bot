# Trading Mode: "paper" or "live"
TRADING_MODE=paper

# Exchange
EXCHANGE=mexc
MEXC_API_KEY=your_api_key_here
MEXC_API_SECRET=your_api_secret_here

# Default leverage for futures
DEFAULT_LEVERAGE=10

# Risk Management -- capital preservation first
MAX_POSITION_SIZE_PCT=5
MAX_DAILY_LOSS_PCT=3
STOP_LOSS_PCT=1.5
TAKE_PROFIT_PCT=5
MAX_CONCURRENT_POSITIONS=3
MIN_SIGNAL_STRENGTH=0.4
CONSECUTIVE_LOSS_COOLDOWN=3

# Liquidity-aware scaling
BREAKEVEN_LOCK_PCT=5.0
INITIAL_ENTRY_PCT=30
MIN_PROFIT_TO_ADD_PCT=1.0
MAX_SCALE_ADDS=3
GAMBLING_BUDGET_PCT=2.0
MIN_LIQUIDITY_VOLUME=1000000

# Pyramid / DCA mode (start small, DCA down, lever up on recovery)
DCA_INTERVAL_PCT=2.0
DCA_MULTIPLIER=1.5
DCA_PROFIT_TO_LEVER_PCT=1.0
DCA_PARTIAL_TAKE_PCT=30

# Hedging (counter-positions on reversal signals)
HEDGE_ENABLED=true
HEDGE_RATIO=0.20
HEDGE_MIN_PROFIT_PCT=3.0
HEDGE_STOP_PCT=1.0
MAX_HEDGES=2

# Email Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFY_EMAIL=your_email@gmail.com

# Notification toggles (comma-separated)
# Available: liquidation,stop_loss,take_profit,order_filled,daily_summary,spike_detected,news_alert
NOTIFICATIONS_ENABLED=liquidation,stop_loss,spike_detected,daily_summary

# Volatility Detection
SPIKE_THRESHOLD_PCT=3.0
VOLATILITY_LOOKBACK_MINUTES=5

# News Monitoring
NEWS_ENABLED=false
NEWS_SOURCES=coindesk,cointelegraph,cryptopanic

# Market Open Windows (UTC hours)
US_MARKET_OPEN_UTC=14
US_MARKET_CLOSE_UTC=21
ASIA_MARKET_OPEN_UTC=1
ASIA_MARKET_CLOSE_UTC=8

# Market Intelligence (external data feeds)
INTEL_ENABLED=true
COINGLASS_API_KEY=                     # optional -- free tier works, paid unlocks more endpoints
FEAR_GREED_POLL=3600                   # Fear & Greed Index poll interval (seconds)
LIQUIDATION_POLL=300                   # CoinGlass liquidation poll interval
MACRO_CALENDAR_POLL=1800               # ForexFactory calendar poll interval
WHALE_SENTIMENT_POLL=300               # CoinGlass funding/OI/L-S poll interval
INTEL_SYMBOLS=BTC,ETH                  # symbols for whale sentiment tracking
MASS_LIQUIDATION_THRESHOLD=1000000000  # $1B = mass liquidation event

# Logging
LOG_LEVEL=INFO
