{
  "uid": "trading-bot",
  "title": "Trade Borg",
  "schemaVersion": 39,
  "tags": ["trading"],
  "timezone": "utc",
  "refresh": "15s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [

    {
      "id": 100,
      "title": "",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 1,
      "title": "System CPU %",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "scheme", "showPoints": "never", "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "system_cpu_percent", "legendFormat": "{{job}}", "refId": "A", "range": true, "instant": false }]
    },
    {
      "id": 2,
      "title": "System Memory",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "scheme", "showPoints": "never", "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Used" }, "properties": [{ "id": "color", "value": { "fixedColor": "#f0883e", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Available" }, "properties": [{ "id": "color", "value": { "fixedColor": "#3fb950", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "system_memory_used_bytes", "legendFormat": "Used", "refId": "A", "range": true, "instant": false },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "system_memory_available_bytes", "legendFormat": "Available", "refId": "B", "range": true, "instant": false }
      ]
    },
    {
      "id": 3,
      "title": "Disk Usage",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 4, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#3fb950", "value": null },
            { "color": "#d29922", "value": 70 },
            { "color": "#f85149", "value": 90 }
          ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "system_disk_percent", "legendFormat": "Disk %", "refId": "A", "range": true, "instant": false }]
    },
    {
      "id": 4,
      "title": "Load Average",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 4, "x": 20, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 0, "showPoints": "never", "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "system_load_1m", "legendFormat": "1m", "refId": "A", "range": true, "instant": false },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "system_load_5m", "legendFormat": "5m", "refId": "B", "range": true, "instant": false },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "system_load_15m", "legendFormat": "15m", "refId": "C", "range": true, "instant": false }
      ]
    },
    {
      "id": 5,
      "title": "Swap Usage",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#3fb950", "value": null },
            { "color": "#d29922", "value": 50 },
            { "color": "#f85149", "value": 80 }
          ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "system_swap_percent", "legendFormat": "Swap", "refId": "A", "range": true, "instant": false }]
    },
    {
      "id": 6,
      "title": "Network I/O",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(system_net_bytes_sent[1m])", "legendFormat": "Sent/s", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(system_net_bytes_recv[1m])", "legendFormat": "Recv/s", "refId": "B" }
      ]
    },
    {
      "id": 7,
      "title": "Memory % (sys + process)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "system_memory_percent", "legendFormat": "System", "refId": "A", "range": true, "instant": false },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "process_memory_percent", "legendFormat": "Bot process", "refId": "B", "range": true, "instant": false }
      ]
    },

    {
      "id": 200,
      "title": "Bot Process",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 10,
      "title": "Process CPU %",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20, "gradientMode": "scheme", "showPoints": "never", "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "process_cpu_percent", "legendFormat": "{{job}}", "refId": "A", "range": true, "instant": false }]
    },
    {
      "id": 11,
      "title": "Process Memory (RSS / VMS)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "process_memory_rss_bytes", "legendFormat": "RSS", "refId": "A", "range": true, "instant": false },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "process_memory_vms_bytes", "legendFormat": "VMS", "refId": "B", "range": true, "instant": false }
      ]
    },
    {
      "id": 12,
      "title": "Threads",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 3, "w": 2, "x": 16, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#58a6ff", "value": null },
            { "color": "#d29922", "value": 50 },
            { "color": "#f85149", "value": 100 }
          ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "process_threads", "legendFormat": "Threads", "refId": "A", "range": true, "instant": false }]
    },
    {
      "id": 13,
      "title": "Open FDs",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 3, "w": 2, "x": 18, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#58a6ff", "value": null },
            { "color": "#d29922", "value": 200 },
            { "color": "#f85149", "value": 500 }
          ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "process_open_fds", "legendFormat": "FDs", "refId": "A", "range": true, "instant": false }]
    },
    {
      "id": 14,
      "title": "GC Objects",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 4, "x": 20, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#d29922" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "hidden" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "python_gc_objects", "legendFormat": "GC objects", "refId": "A", "range": true, "instant": false }]
    },
    {
      "id": 15,
      "title": "GC Collections",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 0, "showPoints": "never", "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(python_gc_collections_total{generation=\"0\"}[5m])", "legendFormat": "Gen 0", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(python_gc_collections_total{generation=\"1\"}[5m])", "legendFormat": "Gen 1", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(python_gc_collections_total{generation=\"2\"}[5m])", "legendFormat": "Gen 2", "refId": "C" }
      ]
    },

    {
      "id": 300,
      "title": "Method Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false,
      "panels": []
    },

    {
      "id": 20,
      "title": "Tick Duration",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "scheme", "showPoints": "never", "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(bot_tick_duration_seconds_sum[5m]) / rate(bot_tick_duration_seconds_count[5m])", "legendFormat": "avg tick", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, rate(bot_tick_duration_seconds_bucket[10m]))", "legendFormat": "p95", "refId": "B" }
      ]
    },
    {
      "id": 21,
      "title": "Event Loop Lag",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 4, "x": 8, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "spanNulls": true },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#3fb950", "value": null },
            { "color": "#d29922", "value": 0.1 },
            { "color": "#f85149", "value": 0.5 }
          ] }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "bot_event_loop_lag_seconds", "legendFormat": "{{job}}", "refId": "A", "range": true, "instant": false }]
    },
    {
      "id": 22,
      "title": "Method Duration — p95",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 0, "showPoints": "never", "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, rate(bot_method_duration_seconds_bucket[5m]))", "legendFormat": "{{ method }}", "refId": "A" }
      ]
    },
    {
      "id": 23,
      "title": "Method Call Rate (per min)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 31 },
      "fieldConfig": {
        "defaults": {
          "unit": "opm",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5, "showPoints": "never", "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(bot_method_duration_seconds_count[1m]) * 60", "legendFormat": "{{ method }}", "refId": "A" }
      ]
    },
    {
      "id": 24,
      "title": "Method Errors (per min)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 31 },
      "fieldConfig": {
        "defaults": {
          "unit": "opm",
          "color": { "mode": "fixed", "fixedColor": "#f85149" },
          "custom": { "lineWidth": 2, "fillOpacity": 20, "showPoints": "never", "spanNulls": true, "drawStyle": "bars" }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(bot_method_errors_total[1m]) * 60", "legendFormat": "{{ method }}", "refId": "A" }
      ]
    }
  ],
  "schemaVersion": 39
}
